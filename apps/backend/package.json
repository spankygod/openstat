{
  "name": "backend",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "seed:dev": "tsx src/scripts/seed-dev.ts",
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/server.ts",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run src/ingestion.integration.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.6.1",
    "@fastify/swagger-ui": "^5.2.6",
    "@openstat/auth": "workspace:*",
    "@openstat/db": "workspace:*",
    "@openstat/ingestion": "workspace:*",
    "@openstat/schemas": "workspace:*",
    "better-auth": "^1.4.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.6.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "tsx": "^4.20.6",
    "typescript": "5.9.2",
    "vitest": "^4.1.5"
  }
}
