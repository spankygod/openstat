NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

DATABASE_URL=postgres://openstat:openstat@localhost:5432/openstat
REDIS_URL=redis://localhost:6379

BETTER_AUTH_SECRET=replace-with-at-least-32-characters

# Local defaults. In production, set these to the deployed backend and web
# origins, for example:
# BETTER_AUTH_URL=https://api.example.com
# API_PUBLIC_URL=https://api.example.com
# APP_WEB_URL=https://app.example.com
BETTER_AUTH_URL=http://localhost:4000
BETTER_AUTH_COOKIE_DOMAIN=
API_PUBLIC_URL=http://localhost:4000
APP_WEB_URL=http://localhost:3000
AUTH_REQUIRE_EMAIL_VERIFICATION=false
AUTH_EMAIL_PROVIDER=log
AUTH_EMAIL_FROM="OpenStat <noreply@openstat.online>"
RESEND_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0

OPENSTAT_DEMO_EMAIL=demo@openstat.local
OPENSTAT_DEMO_PASSWORD=openstat-local-demo-password

INGESTION_MAX_BODY_BYTES=1000000
INGESTION_RATE_LIMIT_MAX=600
INGESTION_RATE_LIMIT_WINDOW=1 minute
DEFAULT_AGENT_STALE_SECONDS=180
DEFAULT_AGENT_OFFLINE_SECONDS=600

INGESTION_WORKER_BATCH_SIZE=100
INGESTION_WORKER_POLL_MS=1000
INGESTION_LOCK_TTL_SECONDS=60
INGESTION_WORKER_MAX_ATTEMPTS=5

RETENTION_SWEEP_ENABLED=false
RETENTION_SWEEP_INTERVAL_MS=3600000
RAW_RETENTION_DAYS=30
DERIVED_RETENTION_DAYS=365
